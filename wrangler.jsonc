{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "carburante",
  "compatibility_date": "2026-07-01",
  // Cloudflare Pages: gli asset statici stanno in public/, le API in functions/.
  // Il build pesante (tessere) gira su GitHub Actions, non a runtime.
  "pages_build_output_dir": "./public"
}
